// Copy to Secrets.xcconfig and fill in. Secrets.xcconfig is gitignored.
API_BASE = https:/$()/clipnote.co.kr
SUPABASE_URL =
SUPABASE_ANON_KEY =
NAVER_CLIENT_ID =
// AdMob: 아래는 구글 공식 "테스트" 공개 ID(실 시크릿 아님). 실배포는 Secrets.xcconfig에 실 ID를 채운다.
// 빈 값이면 GoogleMobileAds SDK가 앱 실행 직후 자동 검증에서 크래시하므로(테스트 호스트 포함),
// 예시/CI 빌드가 정상 실행되도록 테스트 App ID를 기본값으로 둔다.
ADMOB_APP_ID = ca-app-pub-3940256099942544~1458002511
ADMOB_BANNER_UNIT_ID = ca-app-pub-3940256099942544/2435281174
